# ── Cloud LLM (Global Planner) ────────────────────────────────────────────────
# GPT-4o (production): set your key and leave GLOBAL_LLM_* unset
OPENAI_API_KEY=sk-...

# qwen3.5:9b via Ollama (no OpenAI credits needed): uncomment these three lines
# GLOBAL_LLM_BASE_URL=http://localhost:11435/v1
# GLOBAL_LLM_API_KEY=ollama
# GLOBAL_LLM_MODEL=qwen3.5:9b

# ── Edge VLM (Per-drone replanner — Ollama) ───────────────────────────────────
# SSH tunnel: ssh -N -f -L 11435:localhost:11434 <user>@<server-ip>
EDGE_VLM_BASE_URL=http://localhost:11435/v1

# ── Simulator backend ─────────────────────────────────────────────────────────
# "mock"   — built-in Python physics, no simulator needed (default)
# "webots" — Webots extern controller
SIMULATOR_BACKEND=mock

# ── Proxy bypass (needed if Clash/V2Ray is running) ───────────────────────────
NO_PROXY=localhost,127.0.0.1
no_proxy=localhost,127.0.0.1

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
